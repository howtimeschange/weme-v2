# Weme v2 环境变量配置

# ── LLM Provider ──────────────────────────────────────────────────────────────
# 可选: mock | deepseek | minimax | anthropic | claude | openai_compat
WEME_PROVIDER=mock
WEME_MODEL=

# API Keys (根据 provider 设置对应的 key)
WEME_API_KEY=
WEME_BASE_URL=

# DeepSeek
# WEME_PROVIDER=deepseek
# WEME_API_KEY=sk-xxxx
# WEME_MODEL=deepseek-chat

# MiniMax
# WEME_PROVIDER=minimax
# WEME_API_KEY=xxxx
# WEME_MODEL=MiniMax-M2.5

# Anthropic / Claude
# WEME_PROVIDER=anthropic
# WEME_API_KEY=sk-ant-xxxx
# WEME_MODEL=claude-sonnet-4-20250514

# OpenAI-compatible
# WEME_PROVIDER=openai_compat
# WEME_API_KEY=sk-xxxx
# WEME_BASE_URL=https://api.openai.com/v1
# WEME_MODEL=gpt-4o

# ── 运行配置 ─────────────────────────────────────────────────────────────────
WEME_MODE=hybrid   # suggest | auto | hybrid
